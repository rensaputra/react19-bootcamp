// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/"
}

datasource db {
  provider = "sqlite"
}

model AdminUser {
  id       Int    @id @default(autoincrement())
  userType String
  userName String @unique
  password String
}

model ProductType {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id                Int                @id @default(autoincrement())
  name              String
  description       String
  mrp               Float
  sellPrice         Float
  image             String
  productTypeId     Int
  currentStock      Int
  rating            Float?             @default(0)
  smallSize         Int                @default(0)
  mediumSize        Int                @default(0)
  largeSize         Int                @default(0)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  productType       ProductType        @relation(fields: [productTypeId], references: [id])
  salesTransactions SalesTransaction[]
}

model BuyerMaster {
  id           Int           @id @default(autoincrement())
  customerName String
  email        String        @unique
  password     String
  address      String
  city         String
  createdAt    DateTime      @default(now())
  salesMasters SalesMaster[]
}

model SalesMaster {
  id                String             @id @default(uuid())
  bId               Int
  SODateTime        DateTime
  grandTotalPrice   Float
  paymentMode       String
  paymentDetails    String
  buyer             BuyerMaster        @relation(fields: [bId], references: [id])
  salesTransactions SalesTransaction[]
}

model SalesTransaction {
  id           String      @id @default(uuid())
  SMOId        String
  productId    Int
  unitPrice    Float
  qtyPurchased Int
  total        Float
  salesMaster  SalesMaster @relation(fields: [SMOId], references: [id])
  product      Product     @relation(fields: [productId], references: [id])
}
